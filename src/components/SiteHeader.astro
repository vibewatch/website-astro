---
import {
  STRINGS,
  SOURCES,
  TOPICS,
  sourceLabel,
  topicLabel,
  topicMeta,
  type Lang,
  type SourceKey,
  type TopicKey,
} from "~/data/site";
import { feedUrl, getReportsByLang, homeUrl, topicUrl } from "~/lib/reports";

interface Props {
  lang: Lang;
  activeSource?: SourceKey;
  activeTopic?: TopicKey;
  altLangHref?: string;
}

const { lang, activeSource, activeTopic, altLangHref } = Astro.props;
const t = STRINGS[lang];
const otherLang: Lang = lang === "zh" ? "en" : "zh";
const otherLabel = lang === "zh" ? "EN" : "中文";
const otherHref = altLangHref ?? homeUrl(otherLang);

const DEFAULT_TOPIC: TopicKey = "ai";

// Build the map of which topics actually have reports per source (in current lang),
// preserving TOPICS declaration order so the dropdown reads AI · AI Agent · AI Coding.
const reports = await getReportsByLang(lang);
const topicsBySource = new Map<SourceKey, TopicKey[]>();
for (const s of SOURCES) {
  const present = new Set(
    reports.filter((r) => r.source === s.key).map((r) => r.topic),
  );
  const ordered = TOPICS.filter((t) => present.has(t.key)).map(
    (t) => t.key,
  );
  topicsBySource.set(s.key, ordered.length > 0 ? ordered : [DEFAULT_TOPIC]);
}

function primaryTopicFor(key: SourceKey): TopicKey {
  const list = topicsBySource.get(key) ?? [DEFAULT_TOPIC];
  return list.includes(DEFAULT_TOPIC) ? DEFAULT_TOPIC : list[0]!;
}
---
<header class="site-header" data-pagefind-ignore>
  <div class="site-header__inner container">
    <a href={homeUrl(lang)} class="brand" aria-label={t.siteName}>
      <span class="brand__mark" aria-hidden="true">A</span>
      <span class="brand__text">{t.siteName}</span>
    </a>

    <nav class="primary-nav" aria-label={lang === "zh" ? "栏目" : "Sections"}>
      {SOURCES.map((s) => {
        const topics = topicsBySource.get(s.key) ?? [DEFAULT_TOPIC];
        const hasMenu = topics.length > 1;
        const isActiveSource = activeSource === s.key;
        return (
          <div class={"primary-nav__item" + (hasMenu ? " has-menu" : "")}>
            <a
              href={topicUrl(s.key, primaryTopicFor(s.key), lang)}
              class="primary-nav__link"
              aria-current={isActiveSource ? "page" : undefined}
              aria-haspopup={hasMenu ? "true" : undefined}
            >
              <span set:html={s.iconSvg}></span>
              <span>{sourceLabel(s, lang)}</span>
              {hasMenu && (
                <svg class="primary-nav__chev" viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M6 9l6 6 6-6"/>
                </svg>
              )}
            </a>
            {hasMenu && (
              <div class="primary-nav__menu" role="menu">
                {topics.map((k) => {
                  const tm = topicMeta(k);
                  if (!tm) return null;
                  const isActiveTopic = isActiveSource && activeTopic === k;
                  return (
                    <a
                      href={topicUrl(s.key, k, lang)}
                      class="primary-nav__menu-link"
                      role="menuitem"
                      aria-current={isActiveTopic ? "page" : undefined}
                    >
                      {topicLabel(tm, lang)}
                    </a>
                  );
                })}
              </div>
            )}
          </div>
        );
      })}
    </nav>

    <div class="header-actions">
      <button
        class="icon-btn"
        id="pagefind-open"
        type="button"
        aria-label={t.search}
        title={t.search + " (⌘K)"}
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <path d="m21 21-4.3-4.3"/>
        </svg>
      </button>
      <a
        class="icon-btn header-actions__rss"
        href={feedUrl(lang)}
        aria-label="RSS"
        title="RSS"
        rel="alternate"
        type="application/rss+xml"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 11a9 9 0 0 1 9 9"/>
          <path d="M4 4a16 16 0 0 1 16 16"/>
          <circle cx="5" cy="19" r="1"/>
        </svg>
      </a>
      <button
        class="icon-btn"
        id="theme-toggle"
        type="button"
        aria-label="Toggle theme"
        title="Toggle theme"
      >
        <svg class="theme-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
        <svg class="theme-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <a class="lang-btn" href={otherHref} hreflang={otherLang} title={STRINGS[otherLang].siteName}>
        {otherLabel}
      </a>
      <button class="cta-btn" id="subscribe-open" type="button">
        {t.subscribe}
      </button>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    var html = document.documentElement;
    var btn = document.getElementById("theme-toggle");
    if (!btn) return;
    btn.addEventListener("click", function () {
      var current = html.getAttribute("data-theme") === "dark" ? "dark" : "light";
      var next = current === "dark" ? "light" : "dark";
      html.setAttribute("data-theme", next);
      try { localStorage.setItem("theme", next); } catch (_) {}
    });
  })();
</script>
